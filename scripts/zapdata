#!/usr/bin/env node

import fs from "node:fs";
import path from "node:path";
import process from "node:process";
import readline from "node:readline/promises";
import { fileURLToPath } from "node:url";
import { stdin as input, stdout as output } from "node:process";
import dotenv from "dotenv";
import mysql from "mysql2/promise";

const repoRoot = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..");
const envPath = path.join(repoRoot, ".env");

function printUsage() {
  console.error("Usage: ./scripts/zapdata [--yes] <user-email|ALL>");
  console.error("");
  console.error("Deletes only user-owned instance/runtime training data while keeping login rows, console settings, and source catalog data.");
}

const USER_TRAINING_DELETE_STEPS = Object.freeze([
  { key: "workoutSets", tableName: "workout_sets" },
  { key: "workoutExercises", tableName: "workout_exercises" },
  { key: "userProgressions", tableName: "user_progressions" },
  { key: "workouts", tableName: "workouts" },
  { key: "programAssignmentRevisions", tableName: "program_assignment_revisions" },
  { key: "programAssignments", tableName: "program_assignments" },
  { key: "instanceRoutineEntries", tableName: "instance_routine_entries" },
  { key: "instanceProgramRoutines", tableName: "instance_program_routines" },
  { key: "instanceProgramEntries", tableName: "instance_program_entries" },
  { key: "instanceProgressionEntries", tableName: "instance_progression_entries" },
  { key: "instanceProgressions", tableName: "instance_progressions" },
  { key: "instancePrograms", tableName: "instance_programs" }
]);

function parseArgs(argv = []) {
  const args = [...argv];
  const force = args.includes("--yes");
  const positional = args.filter((entry) => entry !== "--yes");

  if (positional.length !== 1) {
    printUsage();
    process.exit(1);
  }

  return {
    force,
    target: String(positional[0] || "").trim()
  };
}

function loadEnv() {
  if (!fs.existsSync(envPath)) {
    throw new Error(`Missing .env at ${envPath}`);
  }

  const result = dotenv.config({
    path: envPath
  });
  if (result.error) {
    throw result.error;
  }

  const requiredKeys = ["DB_HOST", "DB_PORT", "DB_NAME", "DB_USER", "DB_PASSWORD"];
  const missingKeys = requiredKeys.filter((key) => !String(process.env[key] || "").trim());
  if (missingKeys.length > 0) {
    throw new Error(`Missing required .env keys: ${missingKeys.join(", ")}`);
  }
}

async function confirmDestructiveAction(targetLabel) {
  const rl = readline.createInterface({
    input,
    output
  });

  try {
    const answer = await rl.question(
      `Delete training data for ${targetLabel}? Type DELETE to continue: `
    );
    return String(answer || "").trim() === "DELETE";
  } finally {
    rl.close();
  }
}

function createDeletedCounts() {
  return Object.fromEntries(
    USER_TRAINING_DELETE_STEPS.map((step) => [step.key, 0])
  );
}

async function assertExpectedTrainingTablesExist(connection) {
  const expectedTableNames = USER_TRAINING_DELETE_STEPS.map((step) => step.tableName);
  const [tableRows] = await connection.query(
    [
      "SELECT TABLE_NAME AS tableName",
      "FROM INFORMATION_SCHEMA.TABLES",
      "WHERE TABLE_SCHEMA = DATABASE()",
      "AND TABLE_NAME IN (?)"
    ].join(" "),
    [expectedTableNames]
  );
  const existingTableNames = new Set(
    (Array.isArray(tableRows) ? tableRows : [])
      .map((row) => String(row?.tableName || "").trim())
      .filter(Boolean)
  );
  const missingTableNames = expectedTableNames.filter((tableName) => !existingTableNames.has(tableName));

  if (missingTableNames.length > 0) {
    throw new Error(`zapdata schema mismatch. Missing expected table(s): ${missingTableNames.join(", ")}`);
  }
}

async function deleteTrainingDataForUser(connection, { userId }, deletedCounts) {
  for (const step of USER_TRAINING_DELETE_STEPS) {
    const [result] = await connection.query(
      `DELETE FROM \`${step.tableName}\` WHERE user_id = ?`,
      [userId]
    );
    deletedCounts[step.key] += result.affectedRows;
  }
}

async function main() {
  const { force, target } = parseArgs(process.argv.slice(2));
  loadEnv();
  const deleteAllUsers = target === "ALL";
  const confirmationLabel = deleteAllUsers ? "ALL users" : target;

  if (!force) {
    const confirmed = await confirmDestructiveAction(confirmationLabel);
    if (!confirmed) {
      console.error("Aborted.");
      process.exit(1);
    }
  }

  const connection = await mysql.createConnection({
    host: process.env.DB_HOST,
    port: Number(process.env.DB_PORT),
    database: process.env.DB_NAME,
    user: process.env.DB_USER,
    password: process.env.DB_PASSWORD
  });

  const deletedCounts = createDeletedCounts();

  try {
    await connection.beginTransaction();
    await assertExpectedTrainingTablesExist(connection);

    const [userRows] = await connection.query(
      deleteAllUsers
        ? "SELECT id, email FROM users ORDER BY id ASC"
        : "SELECT id, email FROM users WHERE email = ? LIMIT 1",
      deleteAllUsers ? [] : [target]
    );

    const normalizedUsers = Array.isArray(userRows)
      ? userRows
        .filter((row) => row?.id && row?.email)
        .map((row) => ({
          userId: Number(row.id),
          email: String(row.email || "").trim()
        }))
      : [];

    if (normalizedUsers.length < 1) {
      throw new Error(
        deleteAllUsers
          ? "No users found."
          : `No user found for email "${target}".`
      );
    }

    for (const user of normalizedUsers) {
      await deleteTrainingDataForUser(connection, user, deletedCounts);
    }

    await connection.commit();
  } catch (error) {
    await connection.rollback();
    throw error;
  } finally {
    await connection.end();
  }

  console.log(
    deleteAllUsers
      ? "zapdata complete for ALL users"
      : `zapdata complete for ${target}`
  );
  console.log(JSON.stringify(deletedCounts, null, 2));
  console.log("Login rows, console settings, and source catalog data were left intact.");
}

main().catch((error) => {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
});
