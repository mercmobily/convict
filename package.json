  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@jskit-ai/agent-docs": "0.1.28",
    "@jskit-ai/config-eslint": "0.1.66",
    "@jskit-ai/jskit-cli": "0.2.76",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^5.2.1",
