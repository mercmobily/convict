    "@local/program-versions": "file:packages/program-versions",
    "@local/program-entries": "file:packages/program-entries",
    "@local/instance-programs": "file:packages/instance-programs",
    "@local/instance-program-entries": "file:packages/instance-program-entries",
    "@local/instance-program-routines": "file:packages/instance-program-routines",
    "@local/instance-routine-entries": "file:packages/instance-routine-entries",
    "@local/instance-progressions": "file:packages/instance-progressions",
    "@local/instance-progression-entries": "file:packages/instance-progression-entries",
    "@local/program-assignments": "file:packages/program-assignments",
    "@local/program-assignment-revisions": "file:packages/program-assignment-revisions",
    "@local/user-progressions": "file:packages/user-progressions",
    "@local/workouts": "file:packages/workouts",
    "@local/workout-exercises": "file:packages/workout-exercises",
