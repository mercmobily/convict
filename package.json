{
  "name": "convict",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal JSKIT base app (Fastify + Vue)",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "server": "node ./bin/server.js",
    "server:all": "node ./bin/server.js",
    "server:home": "SERVER_SURFACE=home node ./bin/server.js",
    "start": "node ./bin/server.js",
    "devlinks": "jskit app link-local-packages",
    "dev": "vite",
    "dev:all": "vite",
    "dev:home": "VITE_SURFACE=home vite",
    "build": "vite build",
    "build:all": "vite build",
    "build:home": "VITE_SURFACE=home vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "node --test",
    "test:client": "vitest run tests/client",
    "verify": "jskit app verify && npm run --if-present verify:app",
    "release": "jskit app release",
    "jskit:update": "jskit app update-packages",
    "server:auth": "SERVER_SURFACE=auth node ./bin/server.js",
    "dev:auth": "VITE_SURFACE=auth vite",
    "build:auth": "VITE_SURFACE=auth vite build",
    "db:migrate": "knex --knexfile ./knexfile.js migrate:latest",
    "db:migrate:rollback": "knex --knexfile ./knexfile.js migrate:rollback",
    "db:migrate:status": "knex --knexfile ./knexfile.js migrate:list",
    "server:account": "SERVER_SURFACE=account node ./bin/server.js",
    "dev:account": "VITE_SURFACE=account vite",
    "build:account": "VITE_SURFACE=account vite build",
    "server:console": "SERVER_SURFACE=console node ./bin/server.js",
    "dev:console": "VITE_SURFACE=console vite",
    "build:console": "VITE_SURFACE=console vite build",
    "server:app": "SERVER_SURFACE=app node ./bin/server.js",
    "server:admin": "SERVER_SURFACE=admin node ./bin/server.js",
    "dev:app": "VITE_SURFACE=app vite",
    "dev:admin": "VITE_SURFACE=admin vite",
    "build:app": "VITE_SURFACE=app vite build",
    "build:admin": "VITE_SURFACE=admin vite build"
  },
  "dependencies": {
    "@local/main": "file:packages/main",
    "@fastify/static": "^9.1.1",
    "@jskit-ai/kernel": "0.x",
    "fastify": "^5.7.4",
    "json-rest-schema": "1.x.x",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.0",
    "@jskit-ai/http-runtime": "0.x",
    "@mdi/js": "^7.4.47",
    "@tanstack/vue-query": "^5.90.5",
    "@jskit-ai/shell-web": "0.x",
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@jskit-ai/auth-core": "0.x",
    "dotenv": "^16.4.5",
    "@supabase/supabase-js": "^2.57.4",
    "jose": "^6.1.0",
    "@jskit-ai/auth-provider-supabase-core": "0.x",
    "@jskit-ai/auth-web": "0.x",
    "knex": "^3.1.0",
    "@jskit-ai/database-runtime": "0.x",
    "mysql2": "^3.11.2",
    "@jskit-ai/database-runtime-mysql": "0.x",
    "@fastify/multipart": "^9.4.0",
    "@jskit-ai/uploads-runtime": "0.x",
    "@uppy/compressor": "^3.1.0",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/image-editor": "^4.2.0",
    "@uppy/xhr-upload": "^5.1.1",
    "@jskit-ai/uploads-image-web": "0.x",
    "@jskit-ai/json-rest-api-core": "0.x",
    "@jskit-ai/resource-core": "0.x",
    "@jskit-ai/resource-crud-core": "0.x",
    "unstorage": "^1.17.3",
    "@jskit-ai/storage-runtime": "0.x",
    "@jskit-ai/crud-core": "0.x",
    "@local/users": "file:packages/users",
    "@jskit-ai/users-core": "0.x",
    "@jskit-ai/realtime": "0.x",
    "@jskit-ai/users-web": "0.x",
    "@jskit-ai/console-core": "0.x",
    "@jskit-ai/console-web": "0.x",
    "@jskit-ai/workspaces-core": "0.x",
    "@jskit-ai/workspaces-web": "0.x",
    "dompurify": "^3.3.3",
    "marked": "^17.0.4",
    "openai": "^6.22.0",
    "@jskit-ai/assistant-core": "0.x",
    "@jskit-ai/assistant-runtime": "0.x"
  },
  "devDependencies": {
    "@jskit-ai/agent-docs": "0.x",
    "@jskit-ai/config-eslint": "0.x",
    "@jskit-ai/jskit-cli": "0.x",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.39.1",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  }
}
